{
  "name": "personal-site",
  "version": "4.0.0",
  "homepage": "https://peiyuanqi.me/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PeiyuanQi/peiyuanqi.github.io.git"
  },
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "build": "rimraf ./build && vite build",
    "build:pages": "npm run build && node scripts/build-pages.js",
    "predeploy": "rm -fr docs/ && npm run build:pages && mv build docs",
    "deploy": "gh-pages -d docs -t",
    "start": "vite --host 127.0.0.1 --port 3000",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.1.1",
    "@fortawesome/free-brands-svg-icons": "^6.1.1",
    "@fortawesome/free-regular-svg-icons": "^6.1.1",
    "@fortawesome/free-solid-svg-icons": "^6.1.1",
    "@fortawesome/react-fontawesome": "0.1.18",
    "dayjs": "^1.11.3",
    "gh-pages": "^6.3.0",
    "normalize.css": "^8.0.1",
    "prop-types": "^15.8.1",
    "react": "^17.0.1",
    "react-burger-menu": "^3.0.8",
    "react-dom": "^17.0.1",
    "react-ga": "^3.3.0",
    "react-ga4": "^1.4.1",
    "react-markdown": "^5.0.3",
    "react-router-dom": "^5.2.0",
    "rimraf": "^3.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^11.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^7.19.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-react": "^7.30.0",
    "jsdom": "^29.1.1",
    "sass": "^1.52.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
